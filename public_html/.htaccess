# GemTok yerel arşiv — Hostinger / Apache / LiteSpeed uyumlu
# Not: Statik dosyalar tarayıcıdan alınabildiği sürece %100 “kopyalanamaz” yapılamaz.
# UA + robots ile sıradan HTTrack/wget sürümleri sınırlanır; UA taklitlenebilir, gerçek koruma için sunucu tarafı oturum/token gerekir.

DirectoryIndex index.html
AddDefaultCharset UTF-8

# Dizin listelemesi kapalı
Options -Indexes

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), local-network-access=*"
  Header set X-XSS-Protection "1; mode=block"
  Header always set Strict-Transport-Security "max-age=15552000" env=HTTPS
</IfModule>

# Sıkıştırma (metin tabanlı tipler)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml image/svg+xml
</IfModule>

# Önbellek: HTML kısa, varlıklar daha uzun
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 5 minutes"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType application/json "access plus 1 hour"
  ExpiresByType image/jpeg "access plus 14 days"
  ExpiresByType image/png "access plus 14 days"
  ExpiresByType image/webp "access plus 14 days"
  ExpiresByType image/gif "access plus 14 days"
  ExpiresByType image/svg+xml "access plus 14 days"
  ExpiresByType font/woff2 "access plus 30 days"
  ExpiresByType font/woff "access plus 30 days"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(?:css|js|mjs|jpg|jpeg|gif|png|webp|ico|woff2?|svg|wasm)$">
    Header set Cache-Control "public, max-age=604800, immutable"
  </FilesMatch>
  <FilesMatch "\.(?:html|htm)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
</IfModule>

# --- Oyun klasörü: bilinen kopyalayıcı / indirgeç User-Agent (varsayılan UA) ---
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # İstek yolu /game/ altında ve UA eşleşiyorsa 403
  RewriteCond %{REQUEST_URI} (^|/)game/ [NC]
  RewriteCond %{HTTP_USER_AGENT} (HTTrack|WinHTTrack|WebCopier|WebReaper|WebZIP|SiteSnagger|Teleport|SiteSucker|Wget|libwww-perl|Go-http-client|python-requests|Scrapy|aiohttp|java/|Apache-HttpClient) [NC,OR]
  RewriteCond %{HTTP_USER_AGENT} ^curl/ [NC,OR]
  RewriteCond %{HTTP_USER_AGENT} ^HTTPie/ [NC]
  RewriteRule ^ - [F,L]
</IfModule>
