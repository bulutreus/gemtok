Options -Indexes

# Eski v1 kayıt dosyası anahtarları açık metin içerir; web üzerinden asla yayınlama.
<FilesMatch "^(gemtok-license-registry\.json|gemtok-license-sync\.php|gemtok-license-registry\.lock)$">
  Require all denied
  Deny from all
</FilesMatch>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
