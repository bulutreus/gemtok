# GemTok — Hostinger otomatik yukleme ayarlari
# Bu dosyayi kopyalayin: hostinger-deploy.env
# hostinger-deploy.env GIT'E EKLENMEZ (sifre guvenligi).

# hPanel > Dosyalar > FTP Hesaplari (sadece IP/hostname, ftp:// yazmayin)
HOSTINGER_FTP_HOST=82.198.227.222
HOSTINGER_FTP_USER=u409670141.gemtok.store
HOSTINGER_FTP_PASSWORD=buraya-ftp-sifreniz
HOSTINGER_FTP_PORT=21

# Hostinger genelde FTPS (SSL) kullanir
HOSTINGER_FTP_SSL=true

# Uzak klasor: domain FTP hesabi icin genelde / (zaten public_html kokudur)
HOSTINGER_REMOTE_DIR=/

# WinSCP kuruluysa daha hizli senkron icin true (opsiyonel)
HOSTINGER_USE_WINSCP=auto
